APP_NAME=Case Disease Analytics API
APP_ENV=dev
APP_PORT=18080
DEBUG=true

# MySQL example:
# mysql+pymysql://username:password@127.0.0.1:3306/disease_analytics?charset=utf8mb4
DATABASE_URL=mysql+pymysql://root:password@127.0.0.1:3306/disease_analytics?charset=utf8mb4

UPLOAD_DIR=./data/uploads
MAX_UPLOAD_MB=100

# JSON array
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
